# Ignore everything
*

# Except Output folder and its contents
!Output/
!Output/**

# Whitelist specifically generated files, reject everything else (e.g. .dmg, .wav)
Output/**/*
!Output/**/
!Output/**/*.json
!Output/**/*.mp3
!Output/**/*.txt
!Output/**/*.log

# Keep .gitignore itself
!.gitignore

# Ignore RSS feeds folder inside Output
Output/*/rss_feeds/
Output/*/rss_feeds/**

# Secure cookies - NEVER push to git
Input/gemini_cookies.json
gemini_chat_api/

# Dedicated image repository folder
ImageRepo/
